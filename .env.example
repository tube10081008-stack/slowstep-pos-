# 슬로우스텝 POS 환경변수 예시 — 실제 값을 채워 .env로 복사하세요.
# .env 는 .gitignore 에 포함되어 커밋되지 않습니다. 절대 실키를 커밋하지 마세요.

# ── Django ──────────────────────────────────────────────
# 운영(DJANGO_DEBUG=False)에서는 반드시 설정(미설정 시 부팅 거부).
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.vercel.app,localhost,127.0.0.1
DJANGO_SECURE_SSL_REDIRECT=False
# CSRF_TRUSTED_ORIGINS=https://your-project.vercel.app
LOG_LEVEL=INFO

# ── 데이터베이스 (미설정 시 SQLite) ─────────────────────
# Neon 등 관리형 Postgres. 서버리스는 "pooled" 접속 문자열(-pooler) 권장.
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.neon.tech/neondb?sslmode=require

# ── Toss페이먼츠 (미설정 시 Mock 승인) ──────────────────
# TOSS_SECRET_KEY=
# TOSS_CLIENT_KEY=
# TOSS_WEBHOOK_SECRET=
# TOSS_API_BASE=https://api.tosspayments.com

# ── 알림톡 (미설정 시 Mock 발송) ────────────────────────
# ALIMTALK_API_KEY=
# ALIMTALK_SENDER_KEY=
# ALIMTALK_API_BASE=
# ALIMTALK_SENDER_PHONE=
# 광고성 메시지 수신거부 번호(실제 매장 번호로)
ALIMTALK_OPT_OUT_NUMBER=080-0000-0000
